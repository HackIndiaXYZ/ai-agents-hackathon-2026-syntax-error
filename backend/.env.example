PORT=5001
NODE_ENV=development

# MongoDB Atlas — replace with your connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/careeriq

# JWT Secrets — use long random strings in production
JWT_SECRET=your_jwt_secret_minimum_32_characters_here
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_characters_here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Google Gemini AI — get free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP — use App Password (not your main password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=CareerIQ AI <your_email@gmail.com>

# Frontend URL (update for production)
FRONTEND_URL=http://localhost:5173

# Demo Account — create manually or via seeder
DEMO_EMAIL=demo@careeriq.ai
DEMO_PASSWORD=Demo@12345

# Encryption key for storing API keys — exactly 32 characters
ENCRYPTION_KEY=your_32_character_encryption_key_here
