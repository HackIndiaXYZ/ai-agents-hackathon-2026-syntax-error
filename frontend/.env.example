# Local development: leave VITE_API_URL unset — Vite proxies /api to localhost (see vite.config.js)

# Production (Vercel frontend dashboard) — pick ONE approach:
#
# Option A (recommended): use same-origin proxy in vercel.json (no VITE_API_URL needed)
#   Frontend: https://hm-azure-ten.vercel.app
#   Backend:  https://hm-gvhp.vercel.app  (proxied via /api)
#
# Option B: call backend directly (must include /api suffix)
# VITE_API_URL=https://hm-gvhp.vercel.app/api
#
# IMPORTANT: On Vercel frontend, DELETE VITE_API_URL if set to a bare backend URL
# (e.g. https://hm-gvhp-xxx.vercel.app) — that causes /auth/* instead of /api/auth/*
